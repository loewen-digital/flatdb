{
  "name": "@loewen-digital/flatdb",
  "version": "0.1.0",
  "description": "Flat-file document database for TypeScript/JavaScript",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "database",
    "flat-file",
    "document-db",
    "json",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "nanoid": "^5.1.5",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "fake-indexeddb": "^6.2.5",
    "typescript": "^5.8.3",
    "vite": "^6.3.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.1.3"
  }
}
